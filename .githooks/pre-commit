#!/usr/bin/env bash
set -euo pipefail

echo "🔍 Checking for sensitive files and information..."

# Block signing material from being committed
if git diff --cached --name-only | grep -E -q '\.(p12|mobileprovision)$'; then
  echo "🚫 You're trying to commit a signing file (.p12/.mobileprovision). Blocked."
  exit 1
fi

# Normalize code-signing values and bundle identifiers in the Xcode project
# before commit to avoid leaking local provisioning details into the repo.

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only)"

# --- 1. Scrub sensitive environment variables from any staged .xcscheme ---
# Clears `value = "..."` for EnvironmentVariable entries whose key contains
# API_KEY / SECRET / TOKEN / PASSWORD / PASSWD (case-insensitive).
while IFS= read -r scheme; do
  [ -z "$scheme" ] && continue
  echo "🧹 Scrubbing secrets from $scheme..."
  TEMP_SCHEME="$(mktemp)"
  git show ":$scheme" | awk '
    /<EnvironmentVariable/ { scrub = 0 }
    {
      lower = tolower($0)
      if (lower ~ /key[[:space:]]*=[[:space:]]*"[^"]*(api_key|secret|token|password|passwd)[^"]*"/) {
        scrub = 1
      }
      if (scrub && $0 ~ /value[[:space:]]*=[[:space:]]*"/) {
        sub(/value[[:space:]]*=[[:space:]]*"[^"]*"/, "value = \"\"")
        scrub = 0
      }
      print
    }
  ' > "$TEMP_SCHEME"
  HASH=$(git hash-object -w "$TEMP_SCHEME")
  git update-index --cacheinfo 100644 "$HASH" "$scheme"
  rm -f "$TEMP_SCHEME"
done < <(echo "$staged_files" | grep -E '\.xcscheme$' || true)

# --- 2. Scrub code-signing values from the staged project.pbxproj ---
pbxproj_path="CodeTalker.xcodeproj/project.pbxproj"

# Only run if the project file is staged in this commit
if ! echo "$staged_files" | grep -qx "$pbxproj_path"; then
  exit 0
fi

if [ ! -f "$pbxproj_path" ]; then
  exit 0
fi
echo "🧹 Cleaning sensitive information from project.pbxproj..."

TEMP_CLEANED="$(mktemp)"

# Scrub sensitive or machine-specific code signing fields and normalize bundle
# identifier from the STAGED blob (working copy is left untouched).
git show ":$pbxproj_path" | sed -E \
  -e 's/(DEVELOPMENT_TEAM = )[^;]*;/\1"";/g' \
  -e 's/(PROVISIONING_PROFILE_SPECIFIER = )[^;]*;/\1"";/g' \
  -e 's/(PROVISIONING_PROFILE = )[^;]*;/\1"";/g' \
  -e 's/(CODE_SIGN_IDENTITY = )[^;]*;/\1"";/g' \
  -e 's/(PRODUCT_BUNDLE_IDENTIFIER = )[^;]*;/\1"com.example.CodeTalker";/g' \
  > "$TEMP_CLEANED"

# Also strip DevelopmentTeam / ProvisioningStyle from any TargetAttributes block
sed -i '' -E \
  -e 's/(DevelopmentTeam = )[^;]*;/\1"";/g' \
  -e 's/(DevelopmentTeamName = )[^;]*;/\1"";/g' \
  "$TEMP_CLEANED"

# Replace the staged file with the cleaned version
HASH=$(git hash-object -w "$TEMP_CLEANED")
git update-index --cacheinfo 100644 "$HASH" "$pbxproj_path"
rm -f "$TEMP_CLEANED"
echo "✅ Project file cleaned successfully"

exit 0
